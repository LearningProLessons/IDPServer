@page
@model IDPServer.Pages.Index;

 




 

<div class="section-eyebrow mt-5">Administration</div>
<div class="section-title">Identity Management</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-5">

    <div class="col">
        <a href="~/Admin" class="card action-card">
            <div>
                <div class="action-title">Admin Dashboard</div>
                <p class="action-desc">Overview of the IdentityServer administration portal.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Admin/Clients" class="card action-card">
            <div>
                <div class="action-title">Clients</div>
                <p class="action-desc">Manage OAuth2/OpenID Connect clients.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Admin/Clients/New" class="card action-card">
            <div>
                <div class="action-title">New Client</div>
                <p class="action-desc">Register a new application.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Admin/ApiScopes" class="card action-card">
            <div>
                <div class="action-title">API Scopes</div>
                <p class="action-desc">Manage protected API scopes.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Admin/ApiScopes/New" class="card action-card">
            <div>
                <div class="action-title">New API Scope</div>
                <p class="action-desc">Create a new API scope.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Admin/IdentityScopes" class="card action-card">
            <div>
                <div class="action-title">Identity Scopes</div>
                <p class="action-desc">Manage OpenID identity scopes.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Admin/IdentityScopes/New" class="card action-card">
            <div>
                <div class="action-title">New Identity Scope</div>
                <p class="action-desc">Create a new identity scope.</p>
            </div>
        </a>
    </div>

</div>


<div class="section-eyebrow">IdentityServer</div>
<div class="section-title">Protocol Endpoints</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-5">

    <div class="col">
        <a href="~/Consent" class="card action-card">
            <div>
                <div class="action-title">Consent</div>
                <p class="action-desc">Review consent workflow.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Device" class="card action-card">
            <div>
                <div class="action-title">Device Flow</div>
                <p class="action-desc">Device authorization endpoint.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Ciba" class="card action-card">
            <div>
                <div class="action-title">CIBA</div>
                <p class="action-desc">Backchannel Authentication.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Ciba/All" class="card action-card">
            <div>
                <div class="action-title">Pending CIBA Requests</div>
                <p class="action-desc">Pending approvals.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Redirect" class="card action-card">
            <div>
                <div class="action-title">Redirect</div>
                <p class="action-desc">OIDC redirect testing.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/.well-known/openid-configuration" class="card action-card">
            <div>
                <div class="action-title">Discovery Document</div>
                <p class="action-desc">OpenID Connect metadata.</p>
            </div>
        </a>
    </div>

</div>



<div class="section-eyebrow">Sessions</div>
<div class="section-title">Current User</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-5">

    <div class="col">
        <a href="~/Diagnostics" class="card action-card">
            <div>
                <div class="action-title">Diagnostics</div>
                <p class="action-desc">Inspect issued claims.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Grants" class="card action-card">
            <div>
                <div class="action-title">Stored Grants</div>
                <p class="action-desc">Manage consent grants.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/ServerSideSessions" class="card action-card">
            <div>
                <div class="action-title">Server Side Sessions</div>
                <p class="action-desc">Manage active sessions.</p>
            </div>
        </a>
    </div>

</div>


<div class="section-eyebrow">Developer</div>
<div class="section-title">Utilities</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-5">

    <div class="col">
        <a href="~/Portal" class="card action-card">
            <div>
                <div class="action-title">Portal</div>
                <p class="action-desc">Developer portal.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/ExternalLogin/Challenge" class="card action-card">
            <div>
                <div class="action-title">External Login Challenge</div>
                <p class="action-desc">Test external providers.</p>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="~/Home/Error" class="card action-card">
            <div>
                <div class="action-title">Error Page</div>
                <p class="action-desc">Application error page.</p>
            </div>
        </a>
    </div>

</div>


<!-- License -->
@if (Model.License != null)
{
    <div class="section-eyebrow">Deployment</div>
    <div class="section-title">License</div>
    <div class="card mb-4">
        <div class="card-body">
            <dl class="license-grid">
                <div>
                    <dt>Serial number</dt>
                    <dd>@Model.License.SerialNumber</dd>
                </div>
                <div>
                    <dt>Expiration</dt>
                    <dd>@Model.License.Expiration!.Value.ToLongDateString()</dd>
                </div>
            </dl>
        </div>
    </div>
}
