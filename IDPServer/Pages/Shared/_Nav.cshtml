@using Duende.IdentityServer.Extensions

@{
    #nullable enable
    string? name = null;
    if (!true.Equals(ViewData["signed-out"]))
    {
        name = Context.User?.GetDisplayName();
    }

    var initial = !string.IsNullOrWhiteSpace(name) ? name!.Trim().Substring(0, 1).ToUpper() : "?";
    var version = typeof(ClaimsPrincipalLiteExtensions).Assembly.GetName().Version?.ToString(3) ?? "";
}

<!-- ===== Top nav ===== -->
<nav class="app-navbar">
    <a href="~/" class="navbar-brand">
        <img src="~/duende-logo.svg" class="icon-banner" alt="" />
        Duende IdentityServer
    </a>

    @if (!string.IsNullOrWhiteSpace(name))
    {
        <div class="dropdown">
            <a href="#" class="user-menu-trigger dropdown-toggle" data-toggle="dropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="user-avatar">@initial</span>
                @name
            </a>
            <div class="dropdown-menu dropdown-menu-right dropdown-menu-end">
                <div class="user-menu-header">
                    <div class="label">Signed in as</div>
                    <div class="value">@name</div>
                </div>
                <a class="dropdown-item text-danger" asp-page="/Account/Logout/Index">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         style="margin-right:6px;vertical-align:-2px">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Logout
                </a>
            </div>
        </div>
    }
</nav>

<!-- ===== Hero ===== -->
<div class="welcome-page pb-0">
    <div class="welcome-hero">
        <img src="~/duende-logo.svg" class="logo" alt="Duende logo" />
        <div>
            <h1>
                Duende IdentityServer
                <span class="badge bg-secondary">v@version</span>
                <span class="badge bg-success">
                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="margin-right:3px;vertical-align:1px"><circle cx="12" cy="12" r="10"/></svg>
                    Running
                </span>
            </h1>
            <p>
                @if (!string.IsNullOrWhiteSpace(name))
                {
                    <text>Welcome back, @name — here's what's available to you.</text>
                }
                else
                {
                    <text>Single sign-on and token service for your applications and APIs.</text>
                }
            </p>
        </div>
    </div>
</div>
