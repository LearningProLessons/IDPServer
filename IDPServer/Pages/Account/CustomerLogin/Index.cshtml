@page
@model IDPServer.Pages.Account.CustomerLogin.Index

@{
    ViewData["Title"] = "Sign In";
}

<div class="login-page">

    <div class="lead">
        <h1>Sign In</h1>
        <p>Sign in using your mobile number.</p>
    </div>

    <partial name="_ValidationSummary" />

    <div class="row">

        <div class="col-lg-6">

            <div class="card">

                <div class="card-header">
                    <h2>Mobile Login</h2>
                </div>

                <div class="card-body">

                    @if (!Model.View.OtpSent)
                    {
                        <form method="post">

                            <input
                                type="hidden"
                                asp-for="Input.ReturnUrl" />

                            <div class="mb-3">

                                <label asp-for="Input.PhoneNumber"></label>

                                <input
                                    asp-for="Input.PhoneNumber"
                                    class="form-control"
                                    placeholder="0912xxxxxxx"
                                    autocomplete="tel"
                                    autofocus />

                                <span
                                    asp-validation-for="Input.PhoneNumber"
                                    class="text-danger"></span>

                            </div>

                            <div class="d-flex gap-2">

                                <button
                                    type="submit"
                                    class="btn btn-primary"
                                    name="Input.Button"
                                    value="request-otp">

                                    Send verification code

                                </button>

                                <button
                                    type="submit"
                                    class="btn btn-secondary"
                                    name="Input.Button"
                                    value="cancel">

                                    Cancel

                                </button>

                            </div>

                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success">

                            Verification code sent to

                            <strong>@Model.View.PhoneNumber</strong>

                        </div>

                        <form method="post">

                            <input
                                type="hidden"
                                asp-for="Input.ReturnUrl"/>

                            <input
                                type="hidden"
                                asp-for="Input.PhoneNumber"
                                value="@Model.View.PhoneNumber"/>

                            <div class="mb-3">

                                <label asp-for="Input.OtpCode"></label>

                                <input
                                    asp-for="Input.OtpCode"
                                    maxlength="6"
                                    inputmode="numeric"
                                    autocomplete="one-time-code"
                                    class="form-control"
                                    autofocus/>

                                <span
                                    asp-validation-for="Input.OtpCode"
                                    class="text-danger"></span>

                            </div>

                            <div class="d-flex gap-2">

                                <button
                                    type="submit"
                                    class="btn btn-primary"
                                    name="Input.Button"
                                    value="verify-otp">

                                    Verify

                                </button>

                                <button
                                    type="submit"
                                    class="btn btn-secondary"
                                    name="Input.Button"
                                    value="cancel">

                                    Cancel

                                </button>

                            </div>

                        </form>

                        <form method="post" class="mt-3">

                            <input
                                type="hidden"
                                asp-for="Input.ReturnUrl"/>

                            <input
                                type="hidden"
                                asp-for="Input.PhoneNumber"
                                value="@Model.View.PhoneNumber"/>

                            <button
                                type="submit"
                                class="btn btn-link p-0"
                                name="Input.Button"
                                value="request-otp">

                                Didn't receive the code? Send again

                            </button>

                        </form>
                    }

                </div>

            </div>

        </div>

        @if (Model.View.VisibleExternalProviders.Any())
        {
            <div class="col-lg-6">

                <div class="card">

                    <div class="card-header">
                        <h2>External Providers</h2>
                    </div>

                    <div class="card-body">

                        <ul class="list-inline mb-0">

                            @foreach (var provider in Model.View.VisibleExternalProviders)
                            {
                                <li class="list-inline-item mb-2">

                                    <a
                                        class="btn btn-outline-secondary"
                                        asp-page="/ExternalLogin/Challenge"
                                        asp-route-scheme="@provider.AuthenticationScheme"
                                        asp-route-returnUrl="@Model.Input.ReturnUrl">

                                        @provider.DisplayName

                                    </a>

                                </li>
                            }

                        </ul>

                    </div>

                </div>

            </div>
        }

        @if (!Model.View.EnableLocalLogin &&
             !Model.View.VisibleExternalProviders.Any())
        {
            <div class="col-12">

                <div class="alert alert-warning">

                    <strong>Invalid login request.</strong>

                    No authentication providers are available for this client.

                </div>

            </div>
        }

    </div>

</div>

 