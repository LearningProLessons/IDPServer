@page
@model IDPServer.Pages.Account.AdminLogin.Index

@{
    ViewData["Title"] = "Administrator Login";
}

<div class="login-page">

    <div class="lead">
        <h1>Administrator Login</h1>
        <p>Sign in using your username and password.</p>
    </div>

    <partial name="_ValidationSummary" />

    <div class="row">

        @if (Model.View.EnableLocalLogin)
        {
            <div class="col-lg-6">

                <div class="card">

                    <div class="card-header">
                        <h2>Local Account</h2>
                    </div>

                    <div class="card-body">

                        @if (!Model.View.AwaitingTwoFactor)
                        {
                            <form method="post">

                                <input
                                    type="hidden"
                                    asp-for="Input.ReturnUrl"/>

                                <div class="mb-3">

                                    <label asp-for="Input.Username"></label>

                                    <input
                                        asp-for="Input.Username"
                                        class="form-control"
                                        autocomplete="username"
                                        autofocus />

                                    <span
                                        asp-validation-for="Input.Username"
                                        class="text-danger"></span>

                                </div>

                                <div class="mb-3">

                                    <label asp-for="Input.Password"></label>

                                    <input
                                        asp-for="Input.Password"
                                        type="password"
                                        class="form-control"
                                        autocomplete="current-password" />

                                    <span
                                        asp-validation-for="Input.Password"
                                        class="text-danger"></span>

                                </div>

                                @if (Model.View.AllowRememberLogin)
                                {
                                    <div class="form-check mb-3">

                                        <input
                                            asp-for="Input.RememberLogin"
                                            class="form-check-input"/>

                                        <label
                                            asp-for="Input.RememberLogin"
                                            class="form-check-label">
                                        </label>

                                    </div>
                                }

                                <div class="d-flex gap-2">

                                    <button
                                        type="submit"
                                        class="btn btn-primary"
                                        name="Input.Button"
                                        value="login">

                                        Login

                                    </button>

                                    <button
                                        type="submit"
                                        class="btn btn-secondary"
                                        name="Input.Button"
                                        value="cancel">

                                        Cancel

                                    </button>

                                </div>

                            </form>

                            <hr />

                            <a
                                asp-page="/Account/Create"
                                asp-route-returnUrl="@Model.Input.ReturnUrl">

                                Create an account

                            </a>
                        }
                        else
                        {
                            <form method="post">

                                <input
                                    type="hidden"
                                    asp-for="Input.ReturnUrl"/>

                                <p>
                                    Enter the 6-digit code generated by your authenticator application.
                                </p>

                                <div class="mb-3">

                                    <label asp-for="Input.TwoFactorCode"></label>

                                    <input
                                        asp-for="Input.TwoFactorCode"
                                        maxlength="6"
                                        inputmode="numeric"
                                        autocomplete="one-time-code"
                                        class="form-control"
                                        autofocus />

                                    <span
                                        asp-validation-for="Input.TwoFactorCode"
                                        class="text-danger"></span>

                                </div>

                                <div class="form-check mb-3">

                                    <input
                                        asp-for="Input.RememberMachine"
                                        class="form-check-input"/>

                                    <label
                                        asp-for="Input.RememberMachine"
                                        class="form-check-label">
                                    </label>

                                </div>

                                <div class="d-flex gap-2">

                                    <button
                                        type="submit"
                                        class="btn btn-primary"
                                        name="Input.Button"
                                        value="verify-2fa">

                                        Verify

                                    </button>

                                    <button
                                        type="submit"
                                        class="btn btn-secondary"
                                        name="Input.Button"
                                        value="cancel">

                                        Cancel

                                    </button>

                                </div>

                            </form>
                        }

                    </div>

                </div>

            </div>
        }

        @if (Model.View.VisibleExternalProviders.Any())
        {
            <div class="col-lg-6">

                <div class="card">

                    <div class="card-header">
                        <h2>External Providers</h2>
                    </div>

                    <div class="card-body">

                        <ul class="list-inline mb-0">

                            @foreach (var provider in Model.View.VisibleExternalProviders)
                            {
                                <li class="list-inline-item mb-2">

                                    <a
                                        class="btn btn-outline-secondary"
                                        asp-page="/ExternalLogin/Challenge"
                                        asp-route-scheme="@provider.AuthenticationScheme"
                                        asp-route-returnUrl="@Model.Input.ReturnUrl">

                                        @provider.DisplayName

                                    </a>

                                </li>
                            }

                        </ul>

                    </div>

                </div>

            </div>
        }

        @if (!Model.View.EnableLocalLogin &&
             !Model.View.VisibleExternalProviders.Any())
        {
            <div class="col-12">

                <div class="alert alert-warning">

                    <strong>Invalid login request.</strong>

                    No authentication providers are available for this client.

                </div>

            </div>
        }

    </div>

</div>
 